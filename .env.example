# Copy values into your shell, .env, or .env.local when running the Linux
# installer directly from this repository. The scripts do not require this file.

APP_USER=shane
APP_GROUP=shane
SERVICE_NAME=soulecho-astera-demo

DEMO_CONFIGURATION=astera
SOULECHO_HOST=127.0.0.1
SOULECHO_PORT=4173
SOULECHO_BASE_PATH=/soulecho/demo/

OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2:3b
PROFILE_METADATA_EXTRACTION=1
MAX_CONSOLE_MEMORY_LINES=40

# Set to 0 when Ollama is already managed elsewhere.
RUN_OLLAMA_SETUP=1
